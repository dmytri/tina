{
  "name": "@exedev/tina",
  "version": "0.1.0",
  "description": "TINA — There Is No Alternative. Pre-execution tool-call interceptor for Pi and OpenCode.",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./pi": {
      "import": "./dist/pi/index.js",
      "types": "./dist/pi/index.d.ts"
    },
    "./opencode": {
      "import": "./dist/opencode/index.js",
      "types": "./dist/opencode/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "cucumber-js",
    "coverage": "c8 cucumber-js",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "typecheck": "tsc --noEmit",
    "prepare": "tsc"
  },
  "keywords": [
    "tina",
    "alternative",
    "pi",
    "opencode",
    "interceptor"
  ],
  "license": "MIT",
  "devDependencies": {
    "@cucumber/cucumber": "^13.2.0",
    "c8": "^12.0.0",
    "gplint": "^2.5.2",
    "tsx": "^4.23.1"
  }
}
